{
  "name": "js-vm-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build:wasm": "node scripts/build-wasm.js",
    "verify": "node tests/verify.js",
    "test": "node tests/E2E.js",
    "differential": "node tests/Differential.js",
    "fuzz": "node tests/Fuzz.js",
    "fuzz:quick": "node tests/Fuzz.js --r=1 --seeds=1",
    "precommit": "node tests/precommit.js",
    "hooks:install": "git config core.hooksPath .githooks",
    "update:js-fuzzer": "node tests/update-js-fuzzer.js",
    "pages:prepare": "node scripts/prepare-pages.js",
    "pages:verify": "node scripts/prepare-pages.js --verify"
  }
}
